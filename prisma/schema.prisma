// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Szerepkörök (Admin vs Sima vendég)
enum Role {
  USER
  ADMIN
}

// Felhasználók (Vendégek és a Borbély)
model User {
  id            String        @id @default(uuid())
  email         String        @unique
  name          String?
  phone         String?
  role          Role          @default(USER)
  createdAt     DateTime      @default(now())
  
  // Kapcsolat: Egy felhasználónak több foglalása is lehet
  appointments  Appointment[] 
}

// Szolgáltatások (Hajvágás, Szakáll, stb.)
model Service {
  id            String        @id @default(uuid())
  name          String
  description   String?
  durationMins  Int           // Hány perces a szolgáltatás (pl. 45)
  price         Int           // Ár (pl. 5000)
  
  // Kapcsolat: Egy szolgáltatáshoz több foglalás is tartozhat
  appointments  Appointment[]
}

// Maga a Foglalás (FRISSÍTETT TERV)
model Appointment {
  id            String   @id @default(uuid())
  date          DateTime // A pontos nap és időpont
  status        String   @default("PENDING") 
  notes         String?  // + ÚJ: Megjegyzés (pl. "Csak ollóval kérném")
  createdAt     DateTime @default(now())

  // + ÚJ: Vendég adatok (csak akkor töltjük ki, ha NEM bejelentkezve foglal)
  guestName     String?
  guestPhone    String?

  // MÓDOSÍTOTT: A userId opcionális lett (kérdőjel), mert vendég is foglalhat!
  userId        String?  
  user          User?    @relation(fields: [userId], references: [id])
  
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id])
}
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Szerepkörök (Admin vs Sima vendég)
enum Role {
  USER
  ADMIN
}

// Felhasználók (Vendégek és a Borbély)
model User {
  id            String        @id // <-- KIVETTÜK A @default(uuid()) RÉSZT!
  email         String        @unique
  name          String?
  phone         String?
  role          Role          @default(USER)
  createdAt     DateTime      @default(now())
  
  appointments  Appointment[] 
}

model Service {
  id            String        @id @default(uuid())
  name          String
  description   String?
  durationMins  Int           
  price         Int           
  appointments  Appointment[]
}

model Appointment {
  id            String   @id @default(uuid())
  date          DateTime // Kezdés
  endTime       DateTime // <-- ÚJ MEZŐ: Befejezés pontos ideje
  status        String   @default("PENDING") 
  notes         String?
  createdAt     DateTime @default(now())

  guestName     String?
  guestPhone    String?
  guestEmail    String?

  userId        String?  
  user          User?    @relation(fields: [userId], references: [id])
  
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id])
}

// Időblokkolások (Szabadság, ebédszünet, egyéb teendők)
model TimeBlock {
  id        String   @id @default(uuid())
  start     DateTime
  end       DateTime
  title     String?  // Opcionális: pl. "Ebédszünet", "Nyaralás"
  createdAt DateTime @default(now())
}